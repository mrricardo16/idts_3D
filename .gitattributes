# 默认让 Git 自动识别文本；下列规则只约束今后写入或检出的属性，不重规范化历史文件。
* text=auto

# 跨平台文本采用 LF。
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.vue text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.http text eol=lf

# Windows 专用脚本在工作区保持 CRLF。
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# 二进制文件不得进行文本或换行转换。GLB 即使作为正式运行资产也必须保留二进制属性。
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.xls binary
*.vsdx binary
*.rp binary
*.glb binary
*.gltf binary
*.bin binary
*.zip binary
*.7z binary
*.rar binary
*.exe binary
*.dll binary
*.pdb binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
