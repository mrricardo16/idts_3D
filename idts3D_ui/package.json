{
  "name": "idts-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "type-check": "vue-tsc -b",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test --project=chrome",
    "test:e2e:edge": "playwright test --project=edge",
    "test:poc:performance:diagnosis": "npm run build && playwright test --config playwright.performance.config.ts",
    "test:poc:perf-fix-01": "npm run build && playwright test --config playwright.cache.config.ts",
    "export:model-structure": "node scripts/export-model-structure.mjs",
    "inspect:model": "node scripts/inspect-model.mjs",
    "model:inspect": "node scripts/inspect-model.mjs",
    "optimize:model": "node scripts/optimize-model.mjs",
    "generate:lod": "node scripts/generate-lod.mjs",
    "model:lod": "node scripts/generate-lod.mjs",
    "model:budget": "node scripts/check-model-budget.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "3d-tiles-renderer": "0.5.0",
    "three": "0.177.0",
    "vue": "3.5.17"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/three": "0.177.0",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.7.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.63.0",
    "vite": "6.4.3",
    "vitest": "4.1.10",
    "vue-tsc": "2.2.10"
  }
}
